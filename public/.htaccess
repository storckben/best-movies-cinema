# Bloquear todos os crawlers e bots
User-agent: *
Disallow: /

# Headers adicionais para impedir crawling
<FilesMatch "\.(html|htm|php)$">
    Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex, nocache"
</FilesMatch>

# Impedir acesso a arquivos sensíveis
<FilesMatch "\.(js|css|json|xml|txt)$">
    Header set X-Robots-Tag "noindex, nofollow"
</FilesMatch>

# Impedir caching
<FilesMatch "\.(html|htm|js|css)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>